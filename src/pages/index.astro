---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Projects from '../components/Projects.astro';
import { portfolioData } from '../data/portfolio';
---

<Layout>
  <main class="flex-grow">
    <!-- Hero Section -->
    <Hero />

    <!-- Brief Bio Preview Section -->
    <section class="w-full bg-white dark:bg-black py-20 px-6 border-b border-neutral-200 dark:border-neutral-900" aria-label="Introduction Summary">
      <div class="mx-auto max-w-5xl flex flex-col md:flex-row items-start justify-between gap-8">
        <div class="flex flex-col gap-2 max-w-md">
          <span class="font-mono text-xs text-neutral-400 dark:text-neutral-500 uppercase tracking-widest">Introduction</span>
          <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-neutral-900 dark:text-white leading-tight">Engineering interactive interfaces with a focus on details.</h2>
        </div>
        <div class="flex flex-col gap-6 max-w-lg">
          <p class="text-sm md:text-base text-neutral-600 dark:text-neutral-400 leading-relaxed font-sans">
            {portfolioData.personal.about.bio}
          </p>
          <div>
            <a 
              href="/about" 
              class="inline-flex items-center gap-1.5 text-xs font-semibold text-neutral-800 dark:text-white hover:text-neutral-655 dark:hover:text-neutral-300 transition-colors group"
            >
              <span>Read more about my background</span>
              <span class="group-hover:translate-x-0.5 transition-transform duration-200">&rarr;</span>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Projects Gallery -->
    <Projects featuredOnly={true} />

    <!-- Play with me Section -->
    <section class="w-full bg-white dark:bg-black py-24 px-6 border-b border-neutral-200 dark:border-neutral-900" aria-label="Games Zone">
      <div class="mx-auto max-w-5xl">
        <div class="flex flex-col gap-2 mb-16">
          <span class="font-mono text-xs text-neutral-400 dark:text-neutral-500 uppercase tracking-widest">05 / Interactive Zone</span>
          <h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white sm:text-4xl">Play with me</h2>
          <p class="text-xs md:text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed font-sans max-w-xl mt-1">
            Need a short break from code? Challenge me to a game of Chess or try your luck at Snake & Ladder. Built entirely in client-side interactive code.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Chess Card -->
          <a href="/play?game=chess" class="spotlight-card group p-6 flex flex-col gap-6 cursor-pointer">
            <div class="w-full flex items-center justify-center rounded-lg bg-neutral-50 dark:bg-neutral-950 border border-neutral-200 dark:border-neutral-900 overflow-hidden relative aspect-video">
              <!-- macOS Window Header Mockup -->
              <div class="absolute top-0 inset-x-0 h-6 border-b border-neutral-200 dark:border-neutral-900 bg-neutral-100/50 dark:bg-neutral-900/50 flex items-center px-3 gap-1.5 z-10">
                <div class="h-2 w-2 rounded-full bg-neutral-300 dark:bg-neutral-800"></div>
                <div class="h-2 w-2 rounded-full bg-neutral-300 dark:bg-neutral-800"></div>
                <div class="h-2 w-2 rounded-full bg-neutral-300 dark:bg-neutral-800"></div>
              </div>
              
              <!-- Chess Board Mockup SVG -->
              <svg viewBox="0 0 400 200" fill="none" class="w-full h-full p-8 pt-10 text-neutral-400 dark:text-neutral-600 group-hover:scale-[1.02] transition-transform duration-300" aria-hidden="true">
                <!-- Checkered grid snippet -->
                <rect x="140" y="30" width="120" height="120" rx="4" class="fill-neutral-900/5 dark:fill-white/3 stroke-neutral-900/10 dark:stroke-white/5" />
                <g class="opacity-80 dark:opacity-90">
                  <rect x="140" y="30" width="30" height="30" class="fill-neutral-900/10 dark:fill-white/10" />
                  <rect x="200" y="30" width="30" height="30" class="fill-neutral-900/10 dark:fill-white/10" />
                  <rect x="170" y="60" width="30" height="30" class="fill-neutral-900/10 dark:fill-white/10" />
                  <rect x="230" y="60" width="30" height="30" class="fill-neutral-900/10 dark:fill-white/10" />
                  <rect x="140" y="90" width="30" height="30" class="fill-neutral-900/10 dark:fill-white/10" />
                  <rect x="200" y="90" width="30" height="30" class="fill-neutral-900/10 dark:fill-white/10" />
                  <rect x="170" y="120" width="30" height="30" class="fill-neutral-900/10 dark:fill-white/10" />
                  <rect x="230" y="120" width="30" height="30" class="fill-neutral-900/10 dark:fill-white/10" />
                </g>
                <!-- Knight Piece SVG -->
                <path d="M 215 110 C 215 105 210 100 205 100 C 200 100 195 103 192 107 C 190 105 188 105 186 107 L 180 112 C 178 114 178 116 182 118 L 188 120 L 188 135 L 212 135 L 212 120 Z" class="fill-neutral-800 dark:fill-neutral-200 stroke-neutral-900 dark:stroke-white" stroke-width="1.5" />
                <!-- Move trajectory arc -->
                <path d="M 200 135 Q 170 120 155 105" class="stroke-emerald-500/80 dark:stroke-emerald-400/80" stroke-width="2" stroke-dasharray="3 3" />
                <circle cx="155" cy="105" r="4" class="fill-emerald-500 dark:fill-emerald-400" />
              </svg>
            </div>
            <div class="flex flex-col gap-2">
              <h3 class="text-lg font-bold text-neutral-900 dark:text-white tracking-tight flex items-center justify-between">
                <span>Chess Engine</span>
                <span class="text-xs font-mono font-medium text-neutral-400 dark:text-neutral-500">Play Now &rarr;</span>
              </h3>
              <p class="text-xs text-neutral-600 dark:text-neutral-400 leading-relaxed">
                Test your strategies in local pass-and-play or play against the CPU. Features customizable board themes from Emerald Forest to Cyberpunk Neon.
              </p>
            </div>
          </a>

          <!-- Snake & Ladder Card -->
          <a href="/play?game=snakes" class="spotlight-card group p-6 flex flex-col gap-6 cursor-pointer">
            <div class="w-full flex items-center justify-center rounded-lg bg-neutral-50 dark:bg-neutral-950 border border-neutral-200 dark:border-neutral-900 overflow-hidden relative aspect-video">
              <!-- macOS Window Header Mockup -->
              <div class="absolute top-0 inset-x-0 h-6 border-b border-neutral-200 dark:border-neutral-900 bg-neutral-100/50 dark:bg-neutral-900/50 flex items-center px-3 gap-1.5 z-10">
                <div class="h-2 w-2 rounded-full bg-neutral-300 dark:bg-neutral-800"></div>
                <div class="h-2 w-2 rounded-full bg-neutral-300 dark:bg-neutral-800"></div>
                <div class="h-2 w-2 rounded-full bg-neutral-300 dark:bg-neutral-800"></div>
              </div>
              
              <!-- Snake & Ladder Mockup SVG -->
              <svg viewBox="0 0 400 200" fill="none" class="w-full h-full p-8 pt-10 text-neutral-400 dark:text-neutral-600 group-hover:scale-[1.02] transition-transform duration-300" aria-hidden="true">
                <g class="opacity-20">
                  <rect x="140" y="30" width="120" height="120" rx="4" class="stroke-neutral-900/10 dark:stroke-white/5" />
                  <line x1="170" y1="30" x2="170" y2="150" class="stroke-neutral-900/10 dark:stroke-white/5" />
                  <line x1="200" y1="30" x2="200" y2="150" class="stroke-neutral-900/10 dark:stroke-white/5" />
                  <line x1="230" y1="30" x2="230" y2="150" class="stroke-neutral-900/10 dark:stroke-white/5" />
                  <line x1="140" y1="60" x2="260" y2="60" class="stroke-neutral-900/10 dark:stroke-white/5" />
                  <line x1="140" y1="90" x2="260" y2="90" class="stroke-neutral-900/10 dark:stroke-white/5" />
                  <line x1="140" y1="120" x2="260" y2="120" class="stroke-neutral-900/10 dark:stroke-white/5" />
                </g>
                <!-- A Ladder -->
                <g class="stroke-amber-500/80 dark:stroke-amber-400/80" stroke-width="2" stroke-linecap="round">
                  <line x1="155" y1="130" x2="185" y2="50" />
                  <line x1="165" y1="133" x2="195" y2="53" />
                  <line x1="158" y1="120" x2="168" y2="123" />
                  <line x1="166" y1="100" x2="176" y2="103" />
                  <line x1="174" y1="80" x2="184" y2="83" />
                  <line x1="182" y1="60" x2="192" y2="63" />
                </g>
                <!-- A Snake -->
                <path d="M 245 45 Q 230 70 245 95 T 215 135" class="stroke-rose-500/80 dark:stroke-rose-400/80" stroke-width="3" stroke-linecap="round" fill="none" />
                <circle cx="245" cy="45" r="4.5" class="fill-rose-600 dark:fill-rose-500" />
                <circle cx="215" cy="135" r="2" class="fill-rose-400" />
                
                <!-- Player Tokens -->
                <circle cx="185" cy="50" r="6" class="fill-neutral-900 dark:fill-white stroke-neutral-900 dark:stroke-white" />
                <circle cx="215" cy="135" r="6" class="fill-rose-500 stroke-rose-600" />
              </svg>
            </div>
            <div class="flex flex-col gap-2">
              <h3 class="text-lg font-bold text-neutral-900 dark:text-white tracking-tight flex items-center justify-between">
                <span>Snakes & Ladders</span>
                <span class="text-xs font-mono font-medium text-neutral-400 dark:text-neutral-500">Play Now &rarr;</span>
              </h3>
              <p class="text-xs text-neutral-600 dark:text-neutral-400 leading-relaxed">
                Roll the dice and race to 100. Watch out for the slides and climb the rungs! Includes single-player AI mode and multiple retro-futuristic board themes.
              </p>
            </div>
          </a>
        </div>
      </div>
    </section>

    <!-- Action/Call-to-Action Banner -->
    <section class="w-full bg-white dark:bg-black py-20 px-6 border-b border-neutral-200 dark:border-neutral-900" aria-label="Work Together CTA">
      <div class="mx-auto max-w-5xl rounded-2xl border border-neutral-200 dark:border-neutral-900 bg-neutral-50/50 dark:bg-neutral-950/20 p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-8 relative overflow-hidden">
        <div class="absolute inset-0 grid-bg-dense opacity-10"></div>
        <div class="relative z-10 flex flex-col gap-3 max-w-lg">
          <h2 class="text-xl md:text-2xl font-bold text-neutral-900 dark:text-white tracking-tight">Have a project in mind?</h2>
          <p class="text-xs md:text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed font-sans">
            Let's build something exceptional together. I'm always open to discussing new opportunities, frontend architecture, design systems, or direct roles.
          </p>
        </div>
        <div class="relative z-10 flex flex-wrap gap-4 shrink-0">
          <a
            href="/contact"
            class="inline-flex h-10 items-center justify-center rounded-lg bg-neutral-950 text-white dark:bg-white dark:text-black hover:bg-neutral-800 dark:hover:bg-neutral-200 transition-all px-5 text-xs font-medium"
          >
            Get In Touch
          </a>
          <a
            href="/experience"
            class="inline-flex h-10 items-center justify-center rounded-lg border border-neutral-200 dark:border-neutral-800 bg-white dark:bg-black text-neutral-600 dark:text-neutral-300 hover:text-neutral-900 dark:hover:text-white hover:bg-neutral-50 dark:hover:bg-neutral-900 transition-all px-5 text-xs font-medium"
          >
            View Experience
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
