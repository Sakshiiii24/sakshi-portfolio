---
import { portfolioData } from '../data/portfolio';
import Icon from './Icon.astro';
---

<section id="contact" class="w-full bg-white dark:bg-black py-24 px-6 border-b border-neutral-200 dark:border-neutral-900" aria-label="Contact">
  <div class="mx-auto max-w-5xl">
    
    <!-- Section Title -->
    <div class="flex flex-col gap-2 mb-16">
      <span class="font-mono text-xs text-neutral-400 dark:text-neutral-500 uppercase tracking-widest">08 / Connection</span>
      <h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white sm:text-4xl">Get In Touch</h2>
    </div>

    <!-- Contact Box layout -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 items-stretch">
      <!-- Left Box: Narrative invitation + Contact Form -->
      <div class="md:col-span-7 flex flex-col justify-between gap-8 p-8 rounded-xl border border-neutral-200 dark:border-neutral-900 bg-neutral-50/40 dark:bg-neutral-950/40 relative overflow-hidden">
        <div class="absolute inset-0 grid-bg-dense opacity-10"></div>
        <div class="relative z-10 flex flex-col gap-4">
          <h3 class="text-xl font-bold text-neutral-900 dark:text-white tracking-tight">Let's collaborate on something great.</h3>
          <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed font-sans max-w-md">
            Whether you want to discuss a new project, query engineering practices, or just say hello—my inbox is always open. I'll do my best to get back to you within 24 hours.
          </p>
        </div>

        <!-- Contact Form -->
        <form id="contact-form" class="relative z-10 flex flex-col gap-5 w-full" novalidate>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <!-- Name Input Group -->
            <div class="flex flex-col gap-1.5">
              <label for="form-name" class="font-mono text-[10px] uppercase text-neutral-400 dark:text-neutral-500 tracking-wider">Your Name</label>
              <input 
                type="text" 
                id="form-name" 
                name="name" 
                required 
                autocomplete="name"
                placeholder="e.g., John Doe…"
                class="w-full text-xs px-3.5 py-2.5 rounded-lg border border-neutral-200 dark:border-neutral-900 bg-white/30 dark:bg-black/30 text-neutral-900 dark:text-white focus:outline-none focus-visible:ring-1 focus-visible:ring-neutral-950 dark:focus-visible:ring-neutral-100 transition-[border-color,background-color,box-shadow] duration-200"
              />
              <span id="error-name" class="hidden text-[10px] text-red-500 font-sans mt-1" aria-live="polite"></span>
            </div>
            
            <!-- Email Input Group -->
            <div class="flex flex-col gap-1.5">
              <label for="form-email" class="font-mono text-[10px] uppercase text-neutral-400 dark:text-neutral-500 tracking-wider">Your Email</label>
              <input 
                type="email" 
                id="form-email" 
                name="email" 
                required 
                autocomplete="email"
                spellcheck="false"
                placeholder="e.g., john@example.com…"
                class="w-full text-xs px-3.5 py-2.5 rounded-lg border border-neutral-200 dark:border-neutral-900 bg-white/30 dark:bg-black/30 text-neutral-900 dark:text-white focus:outline-none focus-visible:ring-1 focus-visible:ring-neutral-950 dark:focus-visible:ring-neutral-100 transition-[border-color,background-color,box-shadow] duration-200"
              />
              <span id="error-email" class="hidden text-[10px] text-red-500 font-sans mt-1" aria-live="polite"></span>
            </div>
          </div>
          
          <!-- Message Input Group -->
          <div class="flex flex-col gap-1.5">
            <label for="form-message" class="font-mono text-[10px] uppercase text-neutral-400 dark:text-neutral-500 tracking-wider">Message</label>
            <textarea 
              id="form-message" 
              name="message" 
              rows="4" 
              required 
              autocomplete="off"
              placeholder="e.g., Let's connect to discuss frontend opportunities…"
              class="w-full text-xs px-3.5 py-2.5 rounded-lg border border-neutral-200 dark:border-neutral-900 bg-white/30 dark:bg-black/30 text-neutral-900 dark:text-white focus:outline-none focus-visible:ring-1 focus-visible:ring-neutral-950 dark:focus-visible:ring-neutral-100 transition-[border-color,background-color,box-shadow] duration-200 resize-none"
            ></textarea>
            <span id="error-message" class="hidden text-[10px] text-red-500 font-sans mt-1" aria-live="polite"></span>
          </div>

          <!-- Submit Button -->
          <button 
            type="submit" 
            id="form-submit-btn"
            class="flex items-center justify-center gap-2 w-full sm:w-auto self-start px-5 py-2.5 rounded-lg bg-neutral-950 dark:bg-white text-white dark:text-black text-xs font-semibold hover:bg-neutral-800 dark:hover:bg-neutral-200 active:scale-[0.98] focus-visible:ring-1 focus-visible:ring-neutral-950 dark:focus-visible:ring-neutral-100 transition-[border-color,background-color,transform,box-shadow] duration-200 cursor-pointer disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span id="btn-text">Send Message</span>
            <div id="btn-icon" class="flex items-center justify-center transition-transform duration-200">
              <Icon name="arrow-right" size={12} />
            </div>
            <div id="btn-spinner" class="hidden animate-spin">
              <Icon name="loader-2" size={12} />
            </div>
          </button>
          
          <!-- General Status Feedback -->
          <div id="form-status" class="hidden text-xs font-medium p-3.5 rounded-lg border transition-[opacity,transform] duration-300" aria-live="polite"></div>
        </form>
        
        <!-- Quick Email Label -->
        <div class="relative z-10 flex flex-col gap-1 mt-2">
          <span class="font-mono text-[10px] uppercase text-neutral-400 dark:text-neutral-500 tracking-wider">Direct Mail</span>
          <a href={`mailto:${portfolioData.personal.email}`} class="text-sm font-semibold text-neutral-950 dark:text-white hover:text-neutral-700 dark:hover:text-neutral-300 transition-colors">
            {portfolioData.personal.email}
          </a>
        </div>
      </div>

      <!-- Right Box: Tile Grid of Actions -->
      <div class="md:col-span-5 flex flex-col gap-4">
        
        <!-- Email Connect card -->
        <a 
          href={`mailto:${portfolioData.personal.email}`}
          class="flex items-center justify-between p-4 rounded-xl border border-neutral-200 dark:border-neutral-900 bg-neutral-50/20 dark:bg-neutral-950/20 hover:border-neutral-300 dark:hover:border-neutral-800 hover:bg-neutral-100/60 dark:hover:bg-neutral-950/60 transition-all duration-300 group"
          aria-label="Send an email to Sakshi"
        >
          <div class="flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-950 text-neutral-500 dark:text-neutral-400 group-hover:text-neutral-900 dark:group-hover:text-white transition-colors">
              <Icon name="mail" size={14} />
            </div>
            <span class="text-xs font-semibold text-neutral-700 dark:text-neutral-300 group-hover:text-neutral-900 dark:group-hover:text-white transition-colors">Send Email</span>
          </div>
          <Icon name="external-link" size={12} class="text-neutral-400 dark:text-neutral-600 group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors" />
        </a>

        <!-- Copy Email to Clipboard Card (Interactive) -->
        <button
          id="copy-email-btn"
          data-email={portfolioData.personal.email}
          class="flex items-center justify-between p-4 rounded-xl border border-neutral-200 dark:border-neutral-900 bg-neutral-50/20 dark:bg-neutral-950/20 hover:border-neutral-300 dark:hover:border-neutral-800 hover:bg-neutral-100/60 dark:hover:bg-neutral-950/60 transition-all duration-300 group cursor-pointer w-full text-left"
          aria-label="Copy email address to clipboard"
        >
          <div class="flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-950 text-neutral-500 dark:text-neutral-400 group-hover:text-neutral-900 dark:group-hover:text-white transition-colors">
              <Icon name="copy" size={14} id="copy-icon" />
              <Icon name="check" size={14} id="check-icon" class="hidden text-emerald-400" />
            </div>
            <span id="copy-text" class="text-xs font-semibold text-neutral-700 dark:text-neutral-300 group-hover:text-neutral-900 dark:group-hover:text-white transition-colors">Copy Email</span>
          </div>
          <span id="copy-indicator" class="text-[10px] font-mono text-neutral-400 dark:text-neutral-600 group-hover:text-neutral-600 dark:group-hover:text-neutral-400">Click to copy</span>
        </button>

        <!-- LinkedIn Card -->
        <a 
          href={portfolioData.personal.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-between p-4 rounded-xl border border-neutral-200 dark:border-neutral-900 bg-neutral-50/20 dark:bg-neutral-950/20 hover:border-neutral-300 dark:hover:border-neutral-800 hover:bg-neutral-100/60 dark:hover:bg-neutral-950/60 transition-all duration-300 group"
          aria-label="Connect with Sakshi on LinkedIn"
        >
          <div class="flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-950 text-neutral-500 dark:text-neutral-400 group-hover:text-neutral-900 dark:group-hover:text-white transition-colors">
              <Icon name="linkedin" size={14} />
            </div>
            <span class="text-xs font-semibold text-neutral-700 dark:text-neutral-300 group-hover:text-neutral-900 dark:group-hover:text-white transition-colors">LinkedIn</span>
          </div>
          <Icon name="external-link" size={12} class="text-neutral-400 dark:text-neutral-600 group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors" />
        </a>

        <!-- GitHub Card -->
        <a 
          href={portfolioData.personal.github}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-between p-4 rounded-xl border border-neutral-200 dark:border-neutral-900 bg-neutral-50/20 dark:bg-neutral-950/20 hover:border-neutral-300 dark:hover:border-neutral-800 hover:bg-neutral-100/60 dark:hover:bg-neutral-950/60 transition-all duration-300 group"
          aria-label="View Sakshi's projects on GitHub"
        >
          <div class="flex items-center gap-3">
            <div class="flex h-8 w-8 items-center justify-center rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-950 text-neutral-500 dark:text-neutral-400 group-hover:text-neutral-900 dark:group-hover:text-white transition-colors">
              <Icon name="github" size={14} />
            </div>
            <span class="text-xs font-semibold text-neutral-700 dark:text-neutral-300 group-hover:text-neutral-900 dark:group-hover:text-white transition-colors">GitHub Profile</span>
          </div>
          <Icon name="external-link" size={12} class="text-neutral-400 dark:text-neutral-600 group-hover:text-neutral-600 dark:group-hover:text-neutral-300 transition-colors" />
        </a>

      </div>
    </div>
  </div>
</section>

<script>
  const initCopyEmail = () => {
    const copyBtn = document.getElementById('copy-email-btn');
    const copyText = document.getElementById('copy-text');
    const copyIcon = document.getElementById('copy-icon');
    const checkIcon = document.getElementById('check-icon');
    const copyIndicator = document.getElementById('copy-indicator');
    
    if (!copyBtn) return;
    
    const email = copyBtn.getAttribute('data-email') || '';
    let isCopying = false;

    copyBtn.addEventListener('click', async () => {
      if (isCopying) return;
      isCopying = true;
      
      try {
        await navigator.clipboard.writeText(email);
        
        // Visual state change
        if (copyText) copyText.textContent = "Copied!";
        if (copyIndicator) copyIndicator.textContent = "Copied to clipboard";
        copyIcon?.classList.add('hidden');
        checkIcon?.classList.remove('hidden');
        
        // Reset state after delay
        setTimeout(() => {
          if (copyText) copyText.textContent = "Copy Email";
          if (copyIndicator) copyIndicator.textContent = "Click to copy";
          copyIcon?.classList.remove('hidden');
          checkIcon?.classList.add('hidden');
          isCopying = false;
        }, 2000);
        
      } catch (err) {
        console.error('Failed to copy text: ', err);
        if (copyIndicator) copyIndicator.textContent = "Failed to copy";
        isCopying = false;
      }
    });
  };

  const initContactForm = () => {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    if (!form) return;

    const nameInput = document.getElementById('form-name') as HTMLInputElement | null;
    const emailInput = document.getElementById('form-email') as HTMLInputElement | null;
    const messageInput = document.getElementById('form-message') as HTMLTextAreaElement | null;
    
    const errName = document.getElementById('error-name') as HTMLSpanElement | null;
    const errEmail = document.getElementById('error-email') as HTMLSpanElement | null;
    const errMessage = document.getElementById('error-message') as HTMLSpanElement | null;
    
    const submitBtn = document.getElementById('form-submit-btn') as HTMLButtonElement | null;
    const btnText = document.getElementById('btn-text') as HTMLSpanElement | null;
    const btnIcon = document.getElementById('btn-icon') as HTMLDivElement | null;
    const btnSpinner = document.getElementById('btn-spinner') as HTMLDivElement | null;
    const formStatus = document.getElementById('form-status') as HTMLDivElement | null;

    if (!submitBtn || !btnText || !btnIcon || !btnSpinner || !formStatus) return;

    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

    const showError = (input: HTMLElement | null, errEl: HTMLSpanElement | null, msg: string) => {
      if (input) {
        input.classList.add('border-red-500', 'dark:border-red-500');
        input.classList.remove('border-neutral-200', 'dark:border-neutral-900');
      }
      if (errEl) {
        errEl.textContent = msg;
        errEl.classList.remove('hidden');
      }
    };

    const clearErrors = () => {
      [nameInput, emailInput, messageInput].forEach(input => {
        if (input) {
          input.classList.remove('border-red-500', 'dark:border-red-500');
          input.classList.add('border-neutral-200', 'dark:border-neutral-900');
        }
      });
      [errName, errEmail, errMessage].forEach(errEl => {
        if (errEl) {
          errEl.textContent = '';
          errEl.classList.add('hidden');
        }
      });
      formStatus.classList.add('hidden');
      formStatus.className = "hidden text-xs font-medium p-3.5 rounded-lg border transition-[opacity,transform] duration-300";
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearErrors();

      let hasError = false;
      let firstErrorElement: HTMLElement | null = null;

      // Validate Name
      const nameVal = nameInput?.value.trim() || '';
      if (!nameVal) {
        showError(nameInput, errName, 'Name is required.');
        hasError = true;
        firstErrorElement = firstErrorElement || nameInput;
      }

      // Validate Email
      const emailVal = emailInput?.value.trim() || '';
      if (!emailVal) {
        showError(emailInput, errEmail, 'Email is required.');
        hasError = true;
        firstErrorElement = firstErrorElement || emailInput;
      } else if (!emailRegex.test(emailVal)) {
        showError(emailInput, errEmail, 'Please enter a valid email address.');
        hasError = true;
        firstErrorElement = firstErrorElement || emailInput;
      }

      // Validate Message
      const messageVal = messageInput?.value.trim() || '';
      if (!messageVal) {
        showError(messageInput, errMessage, 'Message is required.');
        hasError = true;
        firstErrorElement = firstErrorElement || messageInput;
      }

      if (hasError) {
        if (firstErrorElement) {
          firstErrorElement.focus();
        }
        return;
      }

      // Disable inputs and buttons
      submitBtn.disabled = true;
      if (nameInput) nameInput.disabled = true;
      if (emailInput) emailInput.disabled = true;
      if (messageInput) messageInput.disabled = true;

      // Show sending state
      btnText.textContent = "Sending…";
      btnIcon.classList.add('hidden');
      btnSpinner.classList.remove('hidden');

      try {
        const response = await fetch("https://formsubmit.co/ajax/sakshisrivastava9546@gmail.com", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Accept": "application/json"
          },
          body: JSON.stringify({
            name: nameVal,
            email: emailVal,
            message: messageVal,
            _captcha: "false",
            _subject: "New Message from Portfolio Contact Form"
          })
        });

        const data = await response.json();

        if (response.ok && data.success === "true") {
          // Success state
          formStatus.textContent = "Thank you! Your message has been sent successfully. (Note: If this is your first submission, please check your inbox for an activation email.)";
          formStatus.className = "text-xs font-medium p-3.5 rounded-lg border border-emerald-200/50 bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 transition-[opacity,transform] duration-300";
          formStatus.classList.remove('hidden');
          form.reset();
        } else {
          throw new Error(data.message || 'Submission failed');
        }
      } catch (err) {
        console.error('Contact Form Error:', err);
        formStatus.textContent = "Oops! Something went wrong. Please try again or email me directly.";
        formStatus.className = "text-xs font-medium p-3.5 rounded-lg border border-red-200/50 bg-red-500/10 text-red-600 dark:text-red-400 transition-[opacity,transform] duration-300";
        formStatus.classList.remove('hidden');
      } finally {
        // Re-enable form inputs & button
        submitBtn.disabled = false;
        if (nameInput) nameInput.disabled = false;
        if (emailInput) emailInput.disabled = false;
        if (messageInput) messageInput.disabled = false;

        // Reset button state
        btnText.textContent = "Send Message";
        btnIcon.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
      }
    });
  };

  // Run on initial load and view transitions swap
  initCopyEmail();
  initContactForm();
  document.addEventListener('astro:after-swap', () => {
    initCopyEmail();
    initContactForm();
  });
</script>
