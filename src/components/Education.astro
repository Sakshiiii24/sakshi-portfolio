---
import { portfolioData } from '../data/portfolio';
import Icon from './Icon.astro';
---

<section id="education" class="w-full bg-white dark:bg-black py-24 px-6 border-b border-neutral-200 dark:border-neutral-900" aria-label="Education">
  <div class="mx-auto max-w-5xl">
    
    <!-- Section Title -->
    <div class="flex flex-col gap-2 mb-16">
      <span class="font-mono text-xs text-neutral-400 dark:text-neutral-500 uppercase tracking-widest">05 / Education</span>
      <h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white sm:text-4xl">Academic Foundation</h2>
    </div>

    <!-- Education List Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {portfolioData.education.map(item => (
        <div class="spotlight-card p-6 flex flex-col gap-4">
          <!-- Icon / Header -->
          <div class="flex items-center gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-950 text-neutral-500 dark:text-neutral-400">
              <Icon name="book-open" size={16} />
            </div>
            <div class="flex flex-col">
              <span class="font-mono text-[10px] text-neutral-400 dark:text-neutral-500">{item.period}</span>
              <h3 class="text-sm font-semibold text-neutral-900 dark:text-white tracking-tight leading-tight mt-0.5">{item.institution}</h3>
            </div>
          </div>

          <!-- Academic description -->
          <div class="flex flex-col gap-1.5 pt-2 border-t border-neutral-200 dark:border-neutral-900/60">
            <h4 class="text-xs font-semibold text-neutral-800 dark:text-neutral-200">{item.degree}</h4>
            <p class="text-xs text-neutral-600 dark:text-neutral-400 leading-relaxed font-sans">{item.details}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
