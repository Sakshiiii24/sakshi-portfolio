---
import { portfolioData } from '../data/portfolio';
import Icon from './Icon.astro';
---

<section id="experience" class="w-full bg-white dark:bg-black py-24 px-6 border-b border-neutral-200 dark:border-neutral-900" aria-label="Experience">
  <div class="mx-auto max-w-5xl">
    
    <!-- Section Title -->
    <div class="flex flex-col gap-2 mb-16">
      <span class="font-mono text-xs text-neutral-400 dark:text-neutral-500 uppercase tracking-widest">03 / Journey</span>
      <h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white sm:text-4xl">Work Experience</h2>
    </div>

    <!-- Timeline Wrapper -->
    <div class="relative border-l border-neutral-200 dark:border-neutral-800 ml-3 pl-8 flex flex-col gap-16">
      {portfolioData.experience.map((item) => (
        <div class="relative group">
          <!-- Timeline point dot -->
          <div class="absolute -left-[38px] top-1.5 flex h-4 w-4 items-center justify-center rounded-full border-2 border-neutral-200 dark:border-neutral-800 bg-white dark:bg-black group-hover:border-neutral-900 dark:group-hover:border-white transition-colors duration-300">
            <div class="h-1.5 w-1.5 rounded-full bg-neutral-300 dark:bg-neutral-800 group-hover:bg-neutral-900 dark:group-hover:bg-white transition-colors duration-300"></div>
          </div>

          <!-- Content Card wrapper -->
          <div class="flex flex-col gap-4">
            <!-- Header (Role, Company, Period) -->
            <div class="flex flex-col gap-1">
              <span class="font-mono text-xs text-neutral-400 dark:text-neutral-500 tracking-wider flex items-center gap-1.5">
                <Icon name="calendar" size={11} />
                <span>{item.period}</span>
              </span>
              <h3 class="text-lg font-bold text-neutral-900 dark:text-white tracking-tight mt-1">
                {item.role} <span class="text-neutral-400 dark:text-neutral-500">at</span> <span class="text-neutral-700 dark:text-neutral-300 hover:text-neutral-950 dark:hover:text-white transition-colors cursor-default">{item.company}</span>
              </h3>
              <span class="text-xs text-neutral-400 dark:text-neutral-500 flex items-center gap-1">
                <Icon name="map-pin" size={10} />
                <span>{item.location}</span>
              </span>
            </div>

            <!-- Description details -->
            <ul class="flex flex-col gap-2 list-none" aria-label={`Responsibilities at ${item.company}`}>
              {item.description.map(desc => (
                <li class="text-xs md:text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed pl-4 relative before:absolute before:left-0 before:top-2 before:h-1.5 before:w-1.5 before:rounded-full before:bg-neutral-300 dark:before:bg-neutral-800">
                  {desc}
                </li>
              ))}
            </ul>

            <!-- Tech stack tagging -->
            <div class="flex flex-wrap gap-2 mt-2">
              {item.technologies.map(tech => (
                <span class="px-2 py-0.5 rounded-md border border-neutral-200 dark:border-neutral-900 bg-neutral-50 dark:bg-neutral-950 text-[10px] font-mono text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:border-neutral-300 dark:hover:border-neutral-800 transition-colors">
                  {tech}
                </span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
