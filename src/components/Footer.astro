---
import { portfolioData } from '../data/portfolio';
import Icon from './Icon.astro';

const currentYear = new Date().getFullYear();
---

<footer class="w-full border-t border-neutral-200 dark:border-neutral-900 bg-neutral-50 dark:bg-black py-12 text-neutral-500 font-sans mt-auto">
  <div class="mx-auto max-w-5xl px-6 flex flex-col md:flex-row items-center justify-between gap-6">
    <!-- Brand / Name -->
    <div class="flex flex-col items-center md:items-start gap-1">
      <p class="text-xs text-neutral-600 dark:text-neutral-400 font-medium text-center md:text-left">
        &copy; {currentYear} {portfolioData.personal.name}. All rights reserved.
      </p>
      <p class="text-[10px] text-neutral-400 dark:text-neutral-600">
        Engineered with Astro & Tailwind CSS v4.
      </p>
    </div>

    <!-- Quick Navigation Links -->
    <nav class="flex flex-wrap justify-center gap-x-6 gap-y-2 text-[11px]" aria-label="Footer Navigation">
      <a href="/about" class="hover:text-neutral-950 dark:hover:text-white transition-colors">About</a>
      <a href="/experience" class="hover:text-neutral-950 dark:hover:text-white transition-colors">Experience</a>
      <a href="/projects" class="hover:text-neutral-950 dark:hover:text-white transition-colors">Projects</a>
      <a href="/contact" class="hover:text-neutral-950 dark:hover:text-white transition-colors">Contact</a>
    </nav>

    <!-- Socials links -->
    <div class="flex items-center gap-4">
      <a
        href={portfolioData.personal.github}
        target="_blank"
        rel="noopener noreferrer"
        class="text-neutral-400 dark:text-neutral-500 hover:text-neutral-950 dark:hover:text-white transition-colors"
        aria-label="GitHub profile"
      >
        <Icon name="github" size={16} />
      </a>
      <a
        href={portfolioData.personal.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="text-neutral-400 dark:text-neutral-500 hover:text-neutral-950 dark:hover:text-white transition-colors"
        aria-label="LinkedIn profile"
      >
        <Icon name="linkedin" size={16} />
      </a>
      <a
        href={`mailto:${portfolioData.personal.email}`}
        class="text-neutral-400 dark:text-neutral-500 hover:text-neutral-950 dark:hover:text-white transition-colors"
        aria-label="Send email"
      >
        <Icon name="mail" size={16} />
      </a>
    </div>
  </div>
</footer>
