---
import { portfolioData } from '../data/portfolio';
import Icon from './Icon.astro';

interface Props {
  featuredOnly?: boolean;
}

const { featuredOnly = false } = Astro.props;

const projects = featuredOnly 
  ? portfolioData.projects.filter(p => p.featured)
  : portfolioData.projects;
---

<section id="projects" class="w-full bg-white dark:bg-black py-24 px-6 border-b border-neutral-200 dark:border-neutral-900" aria-label="Projects">
  <div class="mx-auto max-w-5xl">
    
    <!-- Section Title -->
    <div class="flex flex-col gap-2 mb-16">
      <span class="font-mono text-xs text-neutral-400 dark:text-neutral-500 uppercase tracking-widest">04 / Projects</span>
      <h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white sm:text-4xl">
        {featuredOnly ? "Featured Creations" : "All Creations"}
      </h2>
    </div>

    <!-- Projects Grid -->
    <div class="flex flex-col gap-8">
      
      <!-- Loop through projects -->
      {projects.map((project) => {
        const isFeatured = project.featured;
        
        return (
          <div 
            class={`spotlight-card group p-6 flex flex-col ${isFeatured ? 'lg:grid lg:grid-cols-12 gap-8' : 'gap-6'}`}
          >
            <!-- Project Mockup / Image Visual -->
            <div class={`${isFeatured ? 'lg:col-span-6' : 'w-full'} flex items-center justify-center rounded-lg bg-neutral-50 dark:bg-neutral-950 border border-neutral-200 dark:border-neutral-900 overflow-hidden relative aspect-video`}>
              
              <!-- macOS Window Header Mockup -->
              <div class="absolute top-0 inset-x-0 h-6 border-b border-neutral-200 dark:border-neutral-900 bg-neutral-100/50 dark:bg-neutral-900/50 flex items-center px-3 gap-1.5 z-10">
                <div class="h-2 w-2 rounded-full bg-neutral-300 dark:bg-neutral-800"></div>
                <div class="h-2 w-2 rounded-full bg-neutral-300 dark:bg-neutral-800"></div>
                <div class="h-2 w-2 rounded-full bg-neutral-300 dark:bg-neutral-800"></div>
              </div>

              <!-- Stylized SVG Content based on Project Title -->
              {project.title === "Versal UI" && (
                <svg viewBox="0 0 400 200" fill="none" class="w-full h-full p-8 pt-10 text-neutral-400 dark:text-neutral-600">
                  <rect x="20" y="20" width="100" height="24" rx="4" class="fill-neutral-900/5 dark:fill-white/3 stroke-neutral-900/10 dark:stroke-white/5" />
                  <rect x="32" y="27" width="40" height="10" rx="2" class="fill-neutral-900/15 dark:fill-white/10" />
                  
                  <rect x="130" y="20" width="80" height="24" rx="12" class="fill-neutral-900/3 dark:fill-white/3 stroke-neutral-900/10 dark:stroke-white/5" />
                  <circle cx="142" cy="32" r="4" fill="#10b981" />
                  <rect x="154" y="27" width="40" height="10" rx="2" class="fill-neutral-900/10 dark:fill-white/8" />

                  <rect x="20" y="54" width="220" height="40" rx="6" class="fill-neutral-900/3 dark:fill-white/3 stroke-neutral-900/5 dark:stroke-white/5" />
                  <circle cx="36" cy="74" r="8" class="fill-neutral-900/8 dark:fill-white/5" />
                  <rect x="52" y="68" width="100" height="6" rx="1" class="fill-neutral-900/15 dark:fill-white/8" />
                  <rect x="52" y="78" width="60" height="4" rx="1" class="fill-neutral-900/8 dark:fill-white/4" />
                  
                  <!-- Toggle widget slider -->
                  <rect x="300" y="20" width="40" height="20" rx="10" class="fill-neutral-900/8 dark:fill-white/5 stroke-neutral-900/15 dark:stroke-white/10" />
                  <circle cx="328" cy="30" r="7" class="fill-neutral-900 dark:fill-white" />
                  
                  <!-- Accordion / Tabs widget representation -->
                  <line x1="20" y1="120" x2="380" y2="120" class="stroke-neutral-200 dark:stroke-neutral-800" stroke-width="1" />
                  <rect x="20" y="118" width="60" height="4" class="fill-neutral-900 dark:fill-white" />
                  
                  <rect x="20" y="140" width="100" height="30" rx="4" class="fill-neutral-900/3 dark:fill-white/3 stroke-neutral-900/10 dark:stroke-white/5" />
                  <circle cx="35" cy="155" r="4" class="fill-neutral-900/20 dark:fill-white/20" />
                  <rect x="47" y="151" width="50" height="8" rx="2" class="fill-neutral-900/15 dark:fill-white/8" />
                  
                  <rect x="130" y="140" width="100" height="30" rx="4" class="fill-neutral-900/3 dark:fill-white/3 stroke-neutral-900/10 dark:stroke-white/5" />
                  <circle cx="145" cy="155" r="4" class="fill-neutral-900/20 dark:fill-white/20" />
                  <rect x="157" y="151" width="50" height="8" rx="2" class="fill-neutral-900/15 dark:fill-white/8" />
                </svg>
              )}

              {project.title === "Chronos Dashboard" && (
                <svg viewBox="0 0 400 200" fill="none" class="w-full h-full p-8 pt-10 text-neutral-400 dark:text-neutral-600">
                  <!-- Dashboard Grid -->
                  <rect x="20" y="20" width="100" height="50" rx="6" class="fill-neutral-900/3 dark:fill-white/3 stroke-neutral-900/10 dark:stroke-white/5" />
                  <rect x="32" y="30" width="40" height="6" rx="1" class="fill-neutral-900/8 dark:fill-white/5" />
                  <text x="32" y="55" class="fill-neutral-900 dark:fill-white" font-family="monospace" font-size="14" font-weight="bold">99.8%</text>

                  <rect x="130" y="20" width="100" height="50" rx="6" class="fill-neutral-900/3 dark:fill-white/3 stroke-neutral-900/10 dark:stroke-white/5" />
                  <rect x="142" y="30" width="40" height="6" rx="1" class="fill-neutral-900/8 dark:fill-white/5" />
                  <text x="142" y="55" class="fill-neutral-900 dark:fill-white" font-family="monospace" font-size="14" font-weight="bold">14ms</text>

                  <!-- Main chart line -->
                  <rect x="20" y="85" width="360" height="90" rx="6" class="fill-neutral-900/1 dark:fill-white/1 stroke-neutral-900/5 dark:stroke-white/5" />
                  <path d="M 25 155 Q 60 110 100 135 T 200 105 T 300 120 T 375 95" class="stroke-neutral-800/60 dark:stroke-white/40" stroke-width="2" stroke-linecap="round" />
                  <!-- Gridlines inside chart -->
                  <line x1="20" y1="110" x2="380" y2="110" class="stroke-neutral-200/50 dark:stroke-neutral-800/30" stroke-dasharray="2 4" />
                  <line x1="20" y1="140" x2="380" y2="140" class="stroke-neutral-200/50 dark:stroke-neutral-800/30" stroke-dasharray="2 4" />
                </svg>
              )}

              {project.title === "Astro Canvas Engine" && (
                <svg viewBox="0 0 400 200" fill="none" class="w-full h-full p-8 pt-10 text-neutral-400 dark:text-neutral-600">
                  <!-- Stylized Particle Web -->
                  <circle cx="100" cy="80" r="6" class="fill-neutral-900 dark:fill-white" />
                  <circle cx="200" cy="140" r="4" class="fill-neutral-900/30 dark:fill-white/30" />
                  <circle cx="300" cy="70" r="5" class="fill-neutral-900/60 dark:fill-white/60" />
                  <circle cx="150" cy="50" r="3" class="fill-neutral-900/20 dark:fill-white/20" />
                  <circle cx="270" cy="130" r="6" class="fill-neutral-900/40 dark:fill-white/40" />
                  <circle cx="50" cy="130" r="3" class="fill-neutral-900/20 dark:fill-white/20" />

                  <line x1="100" y1="80" x2="200" y2="140" class="stroke-neutral-200 dark:stroke-neutral-800" stroke-width="1" />
                  <line x1="100" y1="80" x2="150" y2="50" class="stroke-neutral-200 dark:stroke-neutral-800" stroke-width="1" />
                  <line x1="200" y1="140" x2="270" y2="130" class="stroke-neutral-200 dark:stroke-neutral-800" stroke-width="1" />
                  <line x1="300" y1="70" x2="270" y2="130" class="stroke-neutral-200 dark:stroke-neutral-800" stroke-width="1" />
                  <line x1="300" y1="70" x2="150" y2="50" class="stroke-neutral-200 dark:stroke-neutral-800" stroke-width="1" />
                  <line x1="50" y1="130" x2="100" y2="80" class="stroke-neutral-200 dark:stroke-neutral-800" stroke-width="1" />
                  
                  <rect x="280" y="20" width="100" height="24" rx="4" class="fill-neutral-900/3 dark:fill-white/3 stroke-neutral-200 dark:stroke-neutral-800" />
                  <text x="290" y="36" class="fill-neutral-500 dark:fill-neutral-400" font-family="monospace" font-size="10">engine: running</text>
                </svg>
              )}

              {project.title === "MiniDB" && (
                <svg viewBox="0 0 400 200" fill="none" class="w-full h-full p-8 pt-10 text-neutral-400 dark:text-neutral-600">
                  <!-- Code Blocks / JSON schema representation -->
                  <text x="30" y="45" class="fill-neutral-500 dark:fill-neutral-400" font-family="monospace" font-size="12">const db = new MiniDB("store");</text>
                  <text x="30" y="65" class="fill-neutral-500 dark:fill-neutral-400" font-family="monospace" font-size="12">db.insert(&#123;</text>
                  <text x="50" y="85" class="fill-neutral-900 dark:fill-white" font-family="monospace" font-size="12">id: "sakshi",</text>
                  <text x="50" y="105" class="fill-neutral-700 dark:fill-neutral-300" font-family="monospace" font-size="12">role: "frontend",</text>
                  <text x="50" y="125" class="fill-emerald-600 dark:fill-emerald-400" font-family="monospace" font-size="12">active: true</text>
                  <text x="30" y="145" class="fill-neutral-500 dark:fill-neutral-400" font-family="monospace" font-size="12">&#125;);</text>

                  <!-- Storage visual -->
                  <rect x="260" y="60" width="110" height="90" rx="6" class="fill-neutral-900/3 dark:fill-white/3 stroke-neutral-200 dark:stroke-neutral-800" />
                  <line x1="260" y1="90" x2="370" y2="90" class="stroke-neutral-200 dark:stroke-neutral-800" />
                  <line x1="260" y1="120" x2="370" y2="120" class="stroke-neutral-200 dark:stroke-neutral-800" />
                  <circle cx="280" cy="75" r="4" fill="#10b981" />
                  <circle cx="280" cy="105" r="4" class="fill-neutral-900 dark:fill-white" />
                  <circle cx="280" cy="135" r="4" class="fill-neutral-200 dark:fill-neutral-800" />
                </svg>
              )}

              {project.title === "Healthcare Management System" && (
                <div class="w-full h-full pt-6">
                  <img 
                    src="/projects/healthcare-management.png" 
                    alt="Healthcare Management System Preview" 
                    class="w-full h-full object-cover"
                  />
                </div>
              )}

              {project.title === "AI Incident Management System" && (
                <svg viewBox="0 0 400 200" fill="none" class="w-full h-full p-8 pt-10 text-neutral-400 dark:text-neutral-600">
                  <!-- Incident Tickets Grid / Kanban preview -->
                  <rect x="20" y="20" width="160" height="65" rx="6" class="fill-neutral-900/3 dark:fill-white/3 stroke-neutral-200 dark:stroke-neutral-900" />
                  <rect x="30" y="30" width="80" height="6" rx="1" class="fill-neutral-900/15 dark:fill-white/10" />
                  <rect x="30" y="42" width="100" height="4" rx="1" class="fill-neutral-900/10 dark:fill-white/5" />
                  <rect x="30" y="50" width="50" height="4" rx="1" class="fill-neutral-900/10 dark:fill-white/5" />
                  <!-- AI Active Tag -->
                  <rect x="120" y="30" width="50" height="14" rx="7" class="fill-emerald-500/10 dark:fill-emerald-500/20 stroke-emerald-500/20" />
                  <text x="128" y="39" class="fill-emerald-600 dark:fill-emerald-400 font-bold" font-family="monospace" font-size="8">Auto-Rx</text>

                  <rect x="20" y="95" width="160" height="65" rx="6" class="fill-neutral-900/3 dark:fill-white/3 stroke-neutral-200 dark:stroke-neutral-900" />
                  <rect x="30" y="105" width="60" height="6" rx="1" class="fill-neutral-900/15 dark:fill-white/10" />
                  <rect x="30" y="117" width="110" height="4" rx="1" class="fill-neutral-900/10 dark:fill-white/5" />
                  <rect x="30" y="125" width="70" height="4" rx="1" class="fill-neutral-900/10 dark:fill-white/5" />
                  <!-- Investigating Tag -->
                  <rect x="120" y="105" width="50" height="14" rx="7" class="fill-amber-500/10 dark:fill-amber-500/20 stroke-amber-500/20" />
                  <text x="126" y="114" class="fill-amber-600 dark:fill-amber-400 font-bold" font-family="monospace" font-size="8">Triage</text>

                  <!-- AI Automation Flow/Neural Network on Right side -->
                  <rect x="200" y="20" width="180" height="140" rx="6" class="fill-neutral-900/1 dark:fill-white/1 stroke-neutral-200/50 dark:stroke-neutral-900/50" />
                  <circle cx="290" cy="90" r="24" class="fill-neutral-900/5 dark:fill-white/5 stroke-neutral-200 dark:stroke-neutral-800" />
                  <circle cx="290" cy="90" r="16" class="fill-neutral-900/10 dark:fill-white/10" />
                  <!-- Sparkles / Spark lines -->
                  <path d="M 290 70 L 290 110 M 270 90 L 310 90" class="stroke-neutral-400 dark:stroke-neutral-600" stroke-width="1.5" />
                  <circle cx="240" cy="55" r="5" class="fill-neutral-900/40 dark:fill-white/40" />
                  <circle cx="240" cy="125" r="5" class="fill-neutral-900/40 dark:fill-white/40" />
                  <circle cx="340" cy="55" r="5" class="fill-neutral-900/40 dark:fill-white/40" />
                  <circle cx="340" cy="125" r="5" class="fill-neutral-900/40 dark:fill-white/40" />
                  
                  <line x1="240" y1="55" x2="274" y2="76" class="stroke-neutral-300 dark:stroke-neutral-800" stroke-dasharray="2 2" />
                  <line x1="240" y1="125" x2="274" y2="104" class="stroke-neutral-300 dark:stroke-neutral-800" stroke-dasharray="2 2" />
                  <line x1="340" y1="55" x2="306" y2="76" class="stroke-neutral-300 dark:stroke-neutral-800" stroke-dasharray="2 2" />
                  <line x1="340" y1="125" x2="306" y2="104" class="stroke-neutral-300 dark:stroke-neutral-800" stroke-dasharray="2 2" />

                  <text x="240" y="152" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px]">Decision Engine: Active</text>
                </svg>
              )}

              {project.title === "Secure Crypt Password Generator" && (
                <svg viewBox="0 0 400 200" fill="none" class="w-full h-full p-8 pt-10 text-neutral-400 dark:text-neutral-600">
                  <!-- Key icon & Title -->
                  <rect x="20" y="20" width="360" height="40" rx="6" class="fill-neutral-900/3 dark:fill-white/3 stroke-neutral-200 dark:stroke-neutral-900" />
                  <!-- Stars representing password -->
                  <circle cx="42" cy="40" r="3.5" class="fill-neutral-900 dark:fill-white" />
                  <circle cx="54" cy="40" r="3.5" class="fill-neutral-900 dark:fill-white" />
                  <circle cx="66" cy="40" r="3.5" class="fill-neutral-900 dark:fill-white" />
                  <circle cx="78" cy="40" r="3.5" class="fill-neutral-900 dark:fill-white" />
                  <circle cx="90" cy="40" r="3.5" class="fill-neutral-900 dark:fill-white" />
                  <circle cx="102" cy="40" r="3.5" class="fill-neutral-900 dark:fill-white" />
                  <circle cx="114" cy="40" r="3.5" class="fill-neutral-900 dark:fill-white" />
                  <circle cx="126" cy="40" r="3.5" class="fill-neutral-900 dark:fill-white" />
                  <circle cx="138" cy="40" r="3.5" class="fill-neutral-900 dark:fill-white" />
                  <circle cx="150" cy="40" r="3.5" class="fill-neutral-900/30 dark:fill-white/30" />
                  <circle cx="162" cy="40" r="3.5" class="fill-neutral-900/30 dark:fill-white/30" />
                  <circle cx="174" cy="40" r="3.5" class="fill-neutral-900/30 dark:fill-white/30" />
                  <!-- Copy icon indicator -->
                  <rect x="344" y="30" width="20" height="20" rx="4" class="fill-neutral-900/5 dark:fill-white/5 stroke-neutral-200 dark:stroke-neutral-800" />
                  <rect x="351" y="38" width="6" height="6" class="stroke-neutral-500 dark:stroke-neutral-400" stroke-width="1" fill="none" />
                  <rect x="348" y="35" width="6" height="6" class="stroke-neutral-500 dark:stroke-neutral-400" stroke-width="1" fill="none" />

                  <!-- Strength and hash details -->
                  <rect x="20" y="70" width="170" height="90" rx="6" class="fill-neutral-900/3 dark:fill-white/3 stroke-neutral-200 dark:stroke-neutral-900" />
                  <text x="32" y="88" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px] uppercase tracking-wider">Strength</text>
                  <text x="32" y="108" class="fill-emerald-600 dark:fill-emerald-400 font-bold" font-family="sans-serif" font-size="14">Very Strong</text>
                  <!-- Strength bar -->
                  <rect x="32" y="122" width="146" height="6" rx="3" class="fill-neutral-200 dark:fill-neutral-850" />
                  <rect x="32" y="122" width="120" height="6" rx="3" class="fill-emerald-500" />
                  <text x="32" y="145" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px]">Entropy: 94.2 bits</text>

                  <!-- Cryptography panel -->
                  <rect x="200" y="70" width="180" height="90" rx="6" class="fill-neutral-900/3 dark:fill-white/3 stroke-neutral-200 dark:stroke-neutral-900" />
                  <text x="212" y="88" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px] uppercase tracking-wider">AES-256-GCM / SHA-256</text>
                  <text x="212" y="110" class="fill-neutral-700 dark:fill-neutral-300 font-mono text-[9px]">Salt: 9f7b11d8e0e64c...</text>
                  <text x="212" y="124" class="fill-neutral-700 dark:fill-neutral-300 font-mono text-[9px]">IV: 2d1a3c5b8f9e0d...</text>
                  <text x="212" y="138" class="fill-neutral-700 dark:fill-neutral-300 font-mono text-[9px]">PBKDF2 Hashing: 100k</text>
                </svg>
              )}

              {project.title === "Interactive Sorting Visualizer" && (
                <svg viewBox="0 0 400 200" fill="none" class="w-full h-full p-8 pt-10 text-neutral-400 dark:text-neutral-600">
                  <!-- Sort Visualizer Bars -->
                  <g class="opacity-80 dark:opacity-90">
                    <rect x="30" y="120" width="12" height="30" rx="2" class="fill-neutral-300 dark:fill-neutral-800" />
                    <rect x="48" y="90" width="12" height="60" rx="2" class="fill-neutral-300 dark:fill-neutral-800" />
                    <rect x="66" y="60" width="12" height="90" rx="2" class="fill-neutral-300 dark:fill-neutral-800" />
                    <!-- Active Comparison (Bar 1) -->
                    <rect x="84" y="105" width="12" height="45" rx="2" class="fill-amber-500 stroke-amber-400" stroke-width="1" />
                    <rect x="102" y="45" width="12" height="105" rx="2" class="fill-neutral-300 dark:fill-neutral-800" />
                    <rect x="120" y="80" width="12" height="70" rx="2" class="fill-neutral-300 dark:fill-neutral-800" />
                    <!-- Active Comparison (Bar 2) -->
                    <rect x="138" y="30" width="12" height="120" rx="2" class="fill-amber-500 stroke-amber-400" stroke-width="1" />
                    <rect x="156" y="115" width="12" height="35" rx="2" class="fill-neutral-300 dark:fill-neutral-800" />
                    <!-- Sorted Elements -->
                    <rect x="174" y="130" width="12" height="20" rx="2" class="fill-emerald-500/80 dark:fill-emerald-500/60" />
                    <rect x="192" y="135" width="12" height="15" rx="2" class="fill-emerald-500/80 dark:fill-emerald-500/60" />
                    <rect x="210" y="140" width="12" height="10" rx="2" class="fill-emerald-500/80 dark:fill-emerald-500/60" />
                  </g>

                  <!-- Array markers -->
                  <path d="M 90 156 L 90 162 M 144 156 L 144 162" class="stroke-amber-500" stroke-width="1.5" />
                  <text x="88" y="172" class="fill-amber-500 font-mono text-[8px] font-bold">i</text>
                  <text x="142" y="172" class="fill-amber-500 font-mono text-[8px] font-bold">j</text>

                  <!-- Dashboard Panel -->
                  <rect x="240" y="30" width="130" height="120" rx="6" class="fill-neutral-900/3 dark:fill-white/3 stroke-neutral-200 dark:stroke-neutral-900" />
                  <text x="252" y="50" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px] uppercase tracking-wider">Status</text>
                  <text x="252" y="68" class="fill-neutral-900 dark:fill-white font-bold" font-family="sans-serif" font-size="12">Quick Sort</text>
                  
                  <text x="252" y="92" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px]">Comparisons</text>
                  <text x="252" y="104" class="fill-neutral-700 dark:fill-neutral-300 font-mono text-[11px] font-bold">1,482</text>

                  <text x="252" y="124" class="fill-neutral-400 dark:fill-neutral-500 font-mono text-[9px]">Swaps</text>
                  <text x="252" y="136" class="fill-neutral-700 dark:fill-neutral-300 font-mono text-[11px] font-bold">649</text>
                </svg>
              )}

              {project.title === "Java Spring Boot CRUD Portal" && (
                <svg viewBox="0 0 400 200" fill="none" class="w-full h-full p-8 pt-10 text-neutral-400 dark:text-neutral-600">
                  <!-- DB Portal / REST API Table Grid -->
                  <rect x="20" y="20" width="360" height="140" rx="6" class="fill-neutral-900/1 dark:fill-white/1 stroke-neutral-200 dark:stroke-neutral-900" />
                  
                  <!-- Table Header -->
                  <rect x="20" y="20" width="360" height="28" rx="0" class="fill-neutral-900/5 dark:fill-white/3 border-b border-neutral-200 dark:border-neutral-900" />
                  <text x="32" y="38" class="fill-neutral-700 dark:fill-neutral-300 font-semibold" font-family="sans-serif" font-size="10">ID</text>
                  <text x="70" y="38" class="fill-neutral-700 dark:fill-neutral-300 font-semibold" font-family="sans-serif" font-size="10">RESOURCE NAME</text>
                  <text x="200" y="38" class="fill-neutral-700 dark:fill-neutral-300 font-semibold" font-family="sans-serif" font-size="10">ROLE</text>
                  <text x="290" y="38" class="fill-neutral-700 dark:fill-neutral-300 font-semibold" font-family="sans-serif" font-size="10">STATUS</text>

                  <!-- Row 1 -->
                  <line x1="20" y1="76" x2="380" y2="76" class="stroke-neutral-200/60 dark:stroke-neutral-900/60" stroke-width="1" />
                  <text x="32" y="63" class="fill-neutral-500 font-mono" font-size="9">#01</text>
                  <text x="70" y="63" class="fill-neutral-900 dark:fill-white font-medium" font-family="sans-serif" font-size="9">Spring JPA service</text>
                  <text x="200" y="63" class="fill-neutral-600 dark:fill-neutral-400" font-family="sans-serif" font-size="9">Data Layer</text>
                  <!-- Status Tag Active -->
                  <rect x="290" y="52" width="40" height="14" rx="4" class="fill-emerald-500/10 dark:fill-emerald-500/25 stroke-emerald-500/20" />
                  <circle cx="297" cy="59" r="2.5" fill="#10b981" />
                  <text x="304" y="62" class="fill-emerald-600 dark:fill-emerald-400 font-bold" font-family="sans-serif" font-size="8">Active</text>

                  <!-- Row 2 -->
                  <line x1="20" y1="112" x2="380" y2="112" class="stroke-neutral-200/60 dark:stroke-neutral-900/60" stroke-width="1" />
                  <text x="32" y="99" class="fill-neutral-500 font-mono" font-size="9">#02</text>
                  <text x="70" y="99" class="fill-neutral-900 dark:fill-white font-medium" font-family="sans-serif" font-size="9">Auth Middleware</text>
                  <text x="200" y="99" class="fill-neutral-600 dark:fill-neutral-400" font-family="sans-serif" font-size="9">Security</text>
                  <!-- Status Tag Pending -->
                  <rect x="290" y="88" width="40" height="14" rx="4" class="fill-amber-500/10 dark:fill-amber-500/25 stroke-amber-500/20" />
                  <circle cx="297" cy="95" r="2.5" fill="#f59e0b" />
                  <text x="304" y="98" class="fill-amber-600 dark:fill-amber-400 font-bold" font-family="sans-serif" font-size="8">Triage</text>

                  <!-- Row 3 -->
                  <text x="32" y="135" class="fill-neutral-500 font-mono" font-size="9">#03</text>
                  <text x="70" y="135" class="fill-neutral-900 dark:fill-white font-medium" font-family="sans-serif" font-size="9">S3 Storage Link</text>
                  <text x="200" y="135" class="fill-neutral-600 dark:fill-neutral-400" font-family="sans-serif" font-size="9">Core Infra</text>
                  <!-- Status Tag Inactive -->
                  <rect x="290" y="124" width="40" height="14" rx="4" class="fill-neutral-200 dark:fill-neutral-800 stroke-neutral-300 dark:stroke-neutral-700" />
                  <circle cx="297" cy="131" r="2.5" class="fill-neutral-400 dark:fill-neutral-500" />
                  <text x="304" y="134" class="fill-neutral-600 dark:fill-neutral-400 font-bold" font-family="sans-serif" font-size="8">Offline</text>
                  
                  <!-- Add Floating Action Button on Bottom Right -->
                  <circle cx="350" cy="135" r="14" class="fill-neutral-900 dark:fill-white hover:scale-105 transition-transform cursor-pointer" />
                  <path d="M 345 135 L 355 135 M 350 130 L 350 140" class="stroke-white dark:stroke-black" stroke-width="2" stroke-linecap="round" />
                </svg>
              )}
            </div>

            <!-- Project Details -->
            <div class={`${isFeatured ? 'lg:col-span-6' : ''} flex flex-col justify-between gap-4`}>
              
              <!-- Header & Description -->
              <div class="flex flex-col gap-2">
                <div class="flex items-center justify-between">
                  <h3 class="text-lg font-bold text-neutral-900 dark:text-white tracking-tight transition-colors">
                    {project.title}
                  </h3>
                  {isFeatured && (
                    <span class="rounded-full bg-neutral-100 dark:bg-white/10 px-2.5 py-0.5 text-[10px] font-mono font-medium text-neutral-800 dark:text-white">
                      Featured
                    </span>
                  )}
                </div>
                <p class="text-xs md:text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed font-sans mt-1">
                  {project.description}
                </p>
              </div>

              <!-- Tech Stack & Links -->
              <div class="flex flex-col gap-4">
                <!-- Stack Tags -->
                <div class="flex flex-wrap gap-1.5">
                  {project.tech.map(tech => (
                    <span class="px-2 py-0.5 rounded-md border border-neutral-200 dark:border-neutral-900 bg-neutral-50 dark:bg-neutral-950 text-[10px] font-mono text-neutral-500 dark:text-neutral-400">
                      {tech}
                    </span>
                  ))}
                </div>

                <!-- Action Links -->
                <div class="flex items-center gap-4 pt-2 border-t border-neutral-200 dark:border-neutral-900/60">
                  <a
                    href={project.github}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1.5 text-xs text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors"
                    aria-label={`View code for ${project.title} on GitHub`}
                  >
                    <Icon name="github" size={13} />
                    <span>Source Code</span>
                  </a>
                  {project.demo && (
                    <a
                      href={project.demo}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-1.5 text-xs text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors"
                      aria-label={`View live demo of ${project.title}`}
                    >
                      <Icon name="external-link" size={13} />
                      <span>Live Demo</span>
                    </a>
                  )}
                </div>
              </div>

            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
