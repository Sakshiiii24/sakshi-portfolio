---
import { portfolioData } from '../data/portfolio';
import Icon from './Icon.astro';

const navItems = [
  { label: "About", href: "/about" },
  { label: "Experience", href: "/experience" },
  { label: "Projects", href: "/projects" },
  { label: "Contact", href: "/contact" }
];
---

<header class="sticky top-0 z-50 w-full border-b border-neutral-200 dark:border-neutral-900 bg-white/60 dark:bg-black/60 backdrop-blur-md transition-all duration-300">
  <div class="mx-auto flex max-w-5xl h-16 items-center justify-between px-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group font-mono text-sm tracking-tight text-neutral-800 dark:text-white font-semibold" aria-label="Sakshi Srivastava - Home">
      <span class="text-neutral-400 dark:text-neutral-500 group-hover:text-neutral-900 dark:group-hover:text-white transition-colors duration-300">&lt;</span>
      <span>{portfolioData.personal.firstName.toLowerCase()}</span>
      <span class="text-neutral-400 dark:text-neutral-500 group-hover:text-neutral-900 dark:group-hover:text-white transition-colors duration-300">.dev /&gt;</span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-6" aria-label="Desktop navigation">
      {navItems.map(item => (
        <a
          href={item.href}
          class="nav-link text-xs tracking-wide text-neutral-500 dark:text-neutral-400 font-medium hover:text-neutral-900 dark:hover:text-white transition-colors duration-200 py-1"
        >
          {item.label}
        </a>
      ))}
      <a
        href={portfolioData.personal.resumeUrl}
        download
        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-950 text-neutral-600 dark:text-neutral-300 hover:text-neutral-900 dark:hover:text-white hover:border-neutral-300 dark:hover:border-neutral-700 hover:bg-neutral-100 dark:hover:bg-neutral-900 transition-all duration-200"
        aria-label="Download Resume"
      >
        <span>Resume</span>
        <Icon name="download" size={12} />
      </a>

      <!-- Desktop Theme Toggle -->
      <button
        id="theme-toggle"
        class="flex h-8 w-8 items-center justify-center rounded-md border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-950 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:bg-neutral-100 dark:hover:bg-neutral-900 transition-colors duration-200 cursor-pointer"
        aria-label="Toggle theme"
      >
        <span class="dark:hidden"><Icon name="moon" size={14} /></span>
        <span class="hidden dark:block"><Icon name="sun" size={14} /></span>
      </button>
    </nav>

    <!-- Mobile Controls (Theme Toggle & Menu Toggle) -->
    <div class="flex md:hidden items-center gap-2">
      <!-- Mobile Theme Toggle -->
      <button
        id="theme-toggle-mobile"
        class="flex h-9 w-9 items-center justify-center rounded-md border border-neutral-200 dark:border-neutral-900 bg-neutral-50/50 dark:bg-neutral-950/50 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white hover:bg-neutral-100 dark:hover:bg-neutral-900 transition-colors duration-200 cursor-pointer"
        aria-label="Toggle theme"
      >
        <span class="dark:hidden"><Icon name="moon" size={16} /></span>
        <span class="hidden dark:block"><Icon name="sun" size={16} /></span>
      </button>

      <!-- Mobile Navigation Toggle -->
      <button
        id="mobile-menu-toggle"
        class="flex h-9 w-9 items-center justify-center rounded-md border border-neutral-200 dark:border-neutral-900 bg-neutral-50/50 dark:bg-neutral-950/50 hover:bg-neutral-100 dark:hover:bg-neutral-900 text-neutral-500 dark:text-neutral-400 hover:text-neutral-900 dark:hover:text-white transition-colors duration-200"
        aria-label="Open navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="menu" size={18} id="icon-menu" />
        <Icon name="close" size={18} id="icon-close" class="hidden" />
      </button>
    </div>
  </div>

  <!-- Mobile Drawer -->
  <div
    id="mobile-menu"
    class="hidden md:hidden fixed inset-x-0 top-16 bottom-0 z-40 bg-white/95 dark:bg-black/95 backdrop-blur-lg border-t border-neutral-200 dark:border-neutral-900 px-6 py-8 flex flex-col justify-between"
    role="dialog"
    aria-modal="true"
    aria-label="Mobile navigation menu"
  >
    <nav class="flex flex-col gap-6" aria-label="Mobile navigation">
      {navItems.map(item => (
        <a
          href={item.href}
          class="mobile-nav-link text-lg text-neutral-700 dark:text-neutral-300 hover:text-neutral-950 dark:hover:text-white font-medium py-2 border-b border-neutral-200 dark:border-neutral-900/50 transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="pt-6 border-t border-neutral-200 dark:border-neutral-900">
      <a
        href={portfolioData.personal.resumeUrl}
        download
        class="flex w-full items-center justify-center gap-2 rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-950 py-3 text-sm font-medium text-neutral-700 dark:text-white hover:bg-neutral-100 dark:hover:bg-neutral-900 transition-colors"
      >
        <span>Download Resume</span>
        <Icon name="download" size={14} />
      </a>
    </div>
  </div>
</header>

<script>
  const setupNav = () => {
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    const iconMenu = document.getElementById('icon-menu');
    const iconClose = document.getElementById('icon-close');
    const mobileLinks = document.querySelectorAll('.mobile-nav-link');
    const navLinks = document.querySelectorAll('.nav-link');
    
    let isMenuOpen = false;

    const toggleMenu = () => {
      isMenuOpen = !isMenuOpen;
      toggleBtn?.setAttribute('aria-expanded', isMenuOpen.toString());
      
      if (isMenuOpen) {
        mobileMenu?.classList.remove('hidden');
        iconMenu?.classList.add('hidden');
        iconClose?.classList.remove('hidden');
        document.body.classList.add('overflow-hidden');
      } else {
        mobileMenu?.classList.add('hidden');
        iconMenu?.classList.remove('hidden');
        iconClose?.classList.add('hidden');
        document.body.classList.remove('overflow-hidden');
      }
    };

    toggleBtn?.addEventListener('click', toggleMenu);

    mobileLinks.forEach(link => {
      link.addEventListener('click', () => {
        if (isMenuOpen) toggleMenu();
      });
    });

    // Close menu on resize to desktop sizes
    window.addEventListener('resize', () => {
      if (window.innerWidth >= 768 && isMenuOpen) {
        toggleMenu();
      }
    });

    // Highlight current active navigation link
    const highlightActiveLink = () => {
      const currentPath = window.location.pathname;
      
      navLinks.forEach(link => {
        const href = link.getAttribute('href');
        if (href && (currentPath === href || (href !== '/' && currentPath.startsWith(href)))) {
          link.classList.remove('text-neutral-500', 'dark:text-neutral-400');
          link.classList.add('text-neutral-900', 'dark:text-white', 'font-semibold');
        } else {
          link.classList.remove('text-neutral-900', 'dark:text-white', 'font-semibold');
          link.classList.add('text-neutral-500', 'dark:text-neutral-400');
        }
      });
    };

    highlightActiveLink();
  };

  const setupTheme = () => {
    const themeBtn = document.getElementById('theme-toggle');
    const themeBtnMobile = document.getElementById('theme-toggle-mobile');
    
    const toggleTheme = () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    };
    
    themeBtn?.addEventListener('click', toggleTheme);
    themeBtnMobile?.addEventListener('click', toggleTheme);
  };

  // Run immediately and on view transition swap
  setupNav();
  setupTheme();
  document.addEventListener('astro:after-swap', () => {
    setupNav();
    setupTheme();
  });
</script>
