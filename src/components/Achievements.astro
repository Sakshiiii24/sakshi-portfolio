---
import { portfolioData } from '../data/portfolio';
import Icon from './Icon.astro';
---

<section id="achievements" class="w-full bg-white dark:bg-black py-24 px-6 border-b border-neutral-200 dark:border-neutral-900" aria-label="Achievements">
  <div class="mx-auto max-w-5xl">
    
    <!-- Section Title -->
    <div class="flex flex-col gap-2 mb-16">
      <span class="font-mono text-xs text-neutral-400 dark:text-neutral-500 uppercase tracking-widest">07 / Accomplishments</span>
      <h2 class="text-3xl font-bold tracking-tight text-neutral-900 dark:text-white sm:text-4xl">Key Achievements</h2>
    </div>

    <!-- Achievements Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {portfolioData.achievements.map(achievement => (
        <div class="spotlight-card p-6 flex flex-col gap-4">
          <!-- Header (Title & Icon) -->
          <div class="flex items-center gap-3">
            <div class="flex h-9 w-9 items-center justify-center rounded-lg border border-neutral-200 dark:border-neutral-800 bg-neutral-50 dark:bg-neutral-950 text-neutral-500 dark:text-neutral-400">
              <Icon name="award" size={16} />
            </div>
            <div class="flex flex-col">
              <span class="font-mono text-[10px] text-neutral-400 dark:text-neutral-500">{achievement.date}</span>
              <h3 class="text-sm font-semibold text-neutral-900 dark:text-white tracking-tight leading-tight mt-0.5">{achievement.title}</h3>
            </div>
          </div>

          <!-- Description -->
          <p class="text-xs md:text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed font-sans pt-2 border-t border-neutral-200 dark:border-neutral-900/60">
            {achievement.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
